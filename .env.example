# ===========================================
# LogLens Environment Configuration
# ===========================================
# Copy this file to .env and update the values

# -------------------------------------------
# Database Configuration (PostgreSQL)
# For Docker: postgresql://user:password@db:5432/dbname
# For Local:  postgresql://user:password@localhost:5432/dbname
# -------------------------------------------
DATABASE_URL=postgresql://loglens:loglens_password@localhost:5432/loglens

# -------------------------------------------
# PostgreSQL Docker Configuration
# These variables are used by docker-compose.yml
# -------------------------------------------
POSTGRES_USER=loglens
POSTGRES_PASSWORD=loglens_password
POSTGRES_DB=loglens
DB_PORT=5432

# -------------------------------------------
# API Server Configuration
# -------------------------------------------
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_PORT=4000

# -------------------------------------------
# Web Frontend Configuration
# -------------------------------------------
NEXT_PUBLIC_API_SERVER=http://localhost:4000
WEB_PORT=3000
