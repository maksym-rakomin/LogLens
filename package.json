{
  "name": "superepo",
  "version": "0.0.1",
  "private": false,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prisma:migrate:dev": "turbo run prisma:migrate:dev --filter=api",
    "prisma:migrate:deploy": "turbo run prisma:migrate:deploy --filter=api",
    "prisma:migrate:reset": "turbo run prisma:migrate:reset --filter=api",
    "prisma:generate": "turbo run prisma:generate --filter=api",
    "prisma:seed": "turbo run prisma:seed --filter=api",
    "prisma:studio": "turbo run prisma:studio --filter=api",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:down:volumes": "docker-compose down -v",
    "docker:logs": "docker-compose logs -f",
    "docker:build": "docker-compose build",
    "docker:rebuild": "docker-compose up -d --build",
    "docker:seed": "docker-compose exec api pnpm prisma:seed",
    "docker:ps": "docker-compose ps",
    "docker:db": "docker-compose exec db psql -U loglens -d loglens"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.2.5",
    "turbo": "^2.3.0",
    "typescript": "5.5.4"
  },
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20"
  }
}
